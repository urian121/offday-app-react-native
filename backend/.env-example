PORT=3000
# Orígenes permitidos para CORS (separados por coma). Apps nativas no lo necesitan.
# Ejemplo: http://localhost:8081,https://tu-dominio.com
CORS_ORIGINS=offday-app-react-native-production.up.railway.app

# Credenciales de OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Credenciales de Turso
TURSO_DATABASE_URL=libsql://xxxxx.turso.io
TURSO_AUTH_TOKEN=xxxxxxxx
